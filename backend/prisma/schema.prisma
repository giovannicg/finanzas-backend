generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  inboxEmail   String        @unique
  pushToken    String?
  totalBudget  Float?
  transactions Transaction[]
  alerts       Alert[]
  categories   Category[]
  createdAt    DateTime      @default(now())
}

model Transaction {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  amount     Float
  merchant   String
  cardLast4  String?
  category   String
  rawText    String
  date       DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
  @@index([userId, category])
}

model Alert {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  category    String
  limitAmount Float
  period      String   // "monthly" | "weekly"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  color     String   @default("#64748B")
  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

model Log {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  type      String   // "AUTH" | "TRANSACTION" | "REQUEST" | "ERROR"
  level     String   @default("INFO") // "INFO" | "WARN" | "ERROR"
  userId    String?
  method    String?
  path      String?
  status    Int?
  duration  Int?
  message   String
  meta      Json?

  @@index([createdAt])
  @@index([userId])
  @@index([type])
  @@index([level])
}
